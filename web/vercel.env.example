AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=auto
AWS_S3_BUCKET=jayaang-merkle
# S3 API endpoint (uploads) — from bucket Settings → General → S3 API
# MUST end in .r2.cloudflarestorage.com — NOT the pub-*.r2.dev URL
