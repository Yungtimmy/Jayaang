# Injective testnet
NEXT_PUBLIC_AIRDROP_CONTRACT=inj1tp592u65uma4hg5g7ykayt8n9l0zp3t6lla0uc
NEXT_PUBLIC_INJECTIVE_TM_RPC=https://testnet.sentry.tm.injective.network:443
NEXT_PUBLIC_INJECTIVE_LCD=https://testnet.sentry.lcd.injective.network

# ── Merkle storage (required on Vercel) ──────────────────────────────────────
# Recommended: Cloudflare R2 (S3-compatible, free tier, no egress fees)
# Alternative: AWS S3 — omit AWS_S3_ENDPOINT for native S3
MERKLE_STORAGE_DRIVER=s3

AWS_ACCESS_KEY_ID=your-r2-access-key-id
AWS_SECRET_ACCESS_KEY=your-r2-secret-access-key
AWS_REGION=auto
AWS_S3_BUCKET=jayaang-merkle
AWS_S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
AWS_S3_PUBLIC_URL=https://pub-YOUR_HASH.r2.dev

# Claims: direct bucket reads (preferred with S3/R2)
NEXT_PUBLIC_MERKLE_BASE_URL=https://pub-YOUR_HASH.r2.dev

# ── Alternatives ─────────────────────────────────────────────────────────────
# Local dev only (default when no S3/Pinata creds and not on Vercel):
# MERKLE_STORAGE_LOCAL=true

# Pinata IPFS (decentralized mirror; claims need API proxy):
# MERKLE_STORAGE_DRIVER=pinata
# PINATA_JWT=your-pinata-jwt
# PINATA_GATEWAY_URL=https://gateway.pinata.cloud/ipfs
# NEXT_PUBLIC_MERKLE_USE_API=true

# Force API proxy for claims (use with Pinata or private buckets):
# NEXT_PUBLIC_MERKLE_USE_API=true