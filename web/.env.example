# Testnet contract (inj1...)
NEXT_PUBLIC_AIRDROP_CONTRACT=inj1tp592u65uma4hg5g7ykayt8n9l0zp3t6lla0uc
NEXT_PUBLIC_INJECTIVE_TM_RPC=https://testnet.sentry.tm.injective.network:443
NEXT_PUBLIC_INJECTIVE_LCD=https://testnet.sentry.lcd.injective.network
# Merkle proof hosting (required on Vercel — filesystem is read-only)
# MERKLE_STORAGE_DRIVER=s3
# MERKLE_STORAGE_LOCAL=true

# AWS S3 (or S3-compatible: Cloudflare R2, MinIO)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket
# AWS_S3_PUBLIC_URL=https://your-bucket.s3.amazonaws.com
# AWS_S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com

# Pinata IPFS (optional mirror; use with MERKLE_STORAGE_DRIVER=pinata or alongside S3)
# PINATA_JWT=
# PINATA_GATEWAY_URL=https://gateway.pinata.cloud/ipfs

# Client-side merkle fetch (pick one strategy)
# NEXT_PUBLIC_MERKLE_BASE_URL=https://your-bucket.s3.amazonaws.com
# NEXT_PUBLIC_MERKLE_USE_API=true
# NEXT_PUBLIC_MERKLE_URL=/merkle-test.json